# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── AI — OpenRouter (default) or Netlify AI Gateway (required for AI features) ─
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: set this to switch from OpenRouter to Netlify AI Gateway in production
# NETLIFY_AI_GATEWAY_URL=https://your-site.netlify.app/.netlify/ai-gateway/v1
# Optional fallback for soil-test extraction when OpenRouter is unavailable
# GEMINI_API_KEY=your_gemini_api_key

# ── Cron endpoints (required in production) ──────────────────────────────────
# Protects /api/cron/weather, /api/cron/compute-fields, /api/cron/sensecap-sync
CRON_SECRET=your_random_secret_here

# ── App URL (required) ───────────────────────────────────────────────────────
# Used for OAuth redirects and by Trigger.dev tasks that invoke internal cron endpoints
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Web Push notifications (required for push; generate with `npx web-push generate-vapid-keys`) ─
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# ── Optional integrations ────────────────────────────────────────────────────
# Trefle plant database — enables crop variety search in block setup
# TREFLE_API_KEY=your_trefle_api_key
# Trigger.dev — background soil-test extraction + scheduled AI runs (falls back to inline processing without it)
# TRIGGER_SECRET_KEY=your_trigger_secret_key
